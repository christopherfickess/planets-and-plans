// EXAMPLE 5: Master-detail layout (big main, small sidebars)
// layout {
//     pane split_direction="vertical" {
//         pane size="15%" {  // Left sidebar
//             command "bash"
//         }
//         pane size="70%" {  // Main central pane
//             command "k9s"
//             args "--headless"
//         }
//         pane size="15%" {  // Right sidebar
//             command "kubectl"
//             args "top" "nodes"
//         }
//     }
// }

// SIZING TIPS:
// - split_direction="vertical" = side-by-side columns (| |)
// - split_direction="horizontal" = stacked rows (top/bottom)
// - Percentages should total 100% (small rounding ok)
// - You can nest splits infinitely
// - Without size specified, panes split evenly
// - Use size="1" for borderless UI elements

// To use this example:
// zellij --layout ~/.dotfiles/sre-tools/zellij/templates/layout-sizing-examples.kdl
