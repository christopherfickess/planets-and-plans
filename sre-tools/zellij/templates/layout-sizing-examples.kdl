// Zellij Layout Sizing Examples
// This file demonstrates different ways to control pane sizes

// EXAMPLE 1: Percentage-based sizing (most common)
// Sizes must add up to 100% (or close to it)
layout {
    pane split_direction="vertical" {
        // Left column: 70% of width
        pane size="70%" split_direction="horizontal" {
            // Top: 40% of height
            pane size="40%" {
                command "k9s"
                args "--headless" "-c" "pods"
            }
            // Bottom: 60% of height
            pane size="60%" {
                command "k9s"
                args "--headless" "-c" "deployments"
            }
        }

        // Right column: 30% of width
        pane size="30%" {
            command "kubectl"
            args "get" "nodes" "-w"
        }
    }
}

