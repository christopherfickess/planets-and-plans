layout {
    pane split_direction="vertical" {
        // Left side - Combined mattermost resources
        pane size="50%" split_direction="horizontal" {
            // All mattermost services (3 namespaces combined)
            pane size="34%" name="📊 HelmReleases (All NS)" {
                command "k9s"
                args "--headless" "-c" "helmrelease" "-A"
            }
            // All mattermost pods (3 namespaces combined)
            pane size="33%" name="📦 All Mattermost Pods" {
                command "k9s"
                args "--headless" "-A" "-c" "pods /mattermost"
            }
            // All mattermost deployments (3 namespaces combined)
                pane size="33%" name="🚀 All Mattermost Deploys" {
                command "k9s"
                args "--headless" "-A" "-c" "deployments /mattermost"
            }
        }

        // Right side - Individual namespace views with k9s
        pane size="50%" split_direction="horizontal" {
            // mattermost-internal (k9s interactive)
            pane size="20%" name="📦 Git Sources (k9s)" {
                command "k9s"
                args "--headless" "-c" "gitrepo" "-n" "flux-system"
            }

            // mattermost-internal (k9s interactive)
            pane size="20%" name="⚙️ Kustomizations (k9s)" {
                command "k9s"
                args "--headless" "-c" "kustomizations" "-n" "flux-system"
            }

            // mattermost-partners (k9s interactive)
            pane size="20%" name="🔌 All Mattermost Services" {                
                command "k9s"
                args "--headless" "-A" "-c" "services /mattermost"
            }

            // mattermost-operator (k9s interactive)
            pane size="20%" name="🌐 Ingress" {
                command "k9s"
                args "--headless" "-A" "-c" "ingress /mattermost"
            }

            // mattermost-operator (k9s interactive)
            pane size="20%" name="📻 HttpRoute" {
                command "k9s"
                args "--headless" "-A" "-c" "httproute /mattermost"
            }
        }
    }

    tab_template name="second_tab" {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
}
